---
import { site } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
---
<div class={dark ? 'card-dark' : 'card'}>
  <div class="flex items-center gap-3 mb-5">
    <span class="tile-icon">
      <Icon name="Clock" size={18} strokeWidth={1.8} />
    </span>
    <h3 class="heading-md">Oeffnungszeiten</h3>
  </div>
  <ul class={`space-y-3 ${dark ? 'text-white/70' : 'text-muted'}`}>
    {site.hoursSummary.map((h) => (
      <li class="flex items-center justify-between text-sm py-2.5 border-b border-line last:border-0">
        <span>{h.label}</span>
        <span class={`font-medium ${dark ? 'text-white' : 'text-onyx'}`}>{h.value}</span>
      </li>
    ))}
  </ul>
  <p class={`mt-5 text-xs ${dark ? 'text-white/50' : 'text-muted-light'}`}>{site.phoneAvailability}</p>
</div>
