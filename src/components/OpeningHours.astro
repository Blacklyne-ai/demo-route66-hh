---
import { site } from '../data/site';
import Icon from './Icon.astro';

interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
---
<div class={dark ? 'card-dark' : 'card'}>
  <div class="flex items-center gap-3 mb-5">
    <span class={`w-10 h-10 rounded inline-flex items-center justify-center ${dark ? 'bg-route text-white' : 'bg-onyx text-route'}`}>
      <Icon name="Clock" size={18} strokeWidth={2.2} />
    </span>
    <h3 class="heading-md">Oeffnungszeiten</h3>
  </div>
  <ul class={`space-y-2 ${dark ? 'text-white/75' : 'text-muted'}`}>
    {site.hoursSummary.map((h) => (
      <li class="flex items-center justify-between text-sm py-2 border-b border-line last:border-0">
        <span class="font-medium">{h.label}</span>
        <span class={`font-display font-semibold ${dark ? 'text-white' : 'text-onyx'}`}>{h.value}</span>
      </li>
    ))}
  </ul>
  <p class={`mt-5 text-xs ${dark ? 'text-white/55' : 'text-muted-light'}`}>{site.phoneAvailability}</p>
</div>
