---
import Icon from './Icon.astro';

interface Props {
  light?: boolean;
}
const { light = false } = Astro.props;
---
<div class={`flex flex-wrap items-center gap-x-8 gap-y-3 ${light ? 'text-white/80' : 'text-muted'}`}>
  <span class="inline-flex items-center gap-2">
    <span class="stars">
      {Array.from({ length: 5 }).map(() => (
        <svg width="14" height="14" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      ))}
    </span>
    <span class={`text-sm ${light ? 'text-white' : 'text-onyx'} font-medium`}>4.9 Google</span>
  </span>
  <span class={`hidden md:inline w-1 h-1 rounded-full ${light ? 'bg-white/30' : 'bg-onyx/20'}`}></span>
  <span class="inline-flex items-center gap-2 text-sm">
    <Icon name="Tv" size={14} strokeWidth={1.8} class="text-route" />
    <span class={`${light ? 'text-white' : 'text-onyx'} font-medium`}>Cash für Chrom DMAX</span>
  </span>
  <span class={`hidden md:inline w-1 h-1 rounded-full ${light ? 'bg-white/30' : 'bg-onyx/20'}`}></span>
  <span class="inline-flex items-center gap-2 text-sm">
    <Icon name="Award" size={14} strokeWidth={1.8} class="text-route" />
    <span class={`${light ? 'text-white' : 'text-onyx'} font-medium`}>Official Shelby Service Partner</span>
  </span>
  <span class={`hidden md:inline w-1 h-1 rounded-full ${light ? 'bg-white/30' : 'bg-onyx/20'}`}></span>
  <span class="inline-flex items-center gap-2 text-sm">
    <Icon name="Wrench" size={14} strokeWidth={1.8} class="text-route" />
    <span class={`${light ? 'text-white' : 'text-onyx'} font-medium`}>EST. 1989</span>
  </span>
</div>
