---
import Icon from './Icon.astro';
import type { Service } from '../data/services';

interface Props {
  service: Service;
}
const { service } = Astro.props;
---
<a href={service.href} class="service-card group">
  <div class="service-media">
    <img src={service.image} alt={service.title} loading="lazy" />
  </div>
  <div class="service-body">
    <p class="eyebrow">{service.eyebrow}</p>
    <h3 class="heading-md mb-3">{service.title}</h3>
    <p class="text-muted leading-relaxed flex-1 mb-5">{service.tagline}</p>
    <div class="flex items-center justify-between pt-4 border-t border-line">
      <span class="arrow-link">
        Mehr erfahren <Icon name="ArrowRight" size={14} strokeWidth={2} />
      </span>
      {service.price && (
        <span class="text-xs text-muted-light">{service.price}</span>
      )}
    </div>
  </div>
</a>
