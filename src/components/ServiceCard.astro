---
import Icon from './Icon.astro';
import type { Service } from '../data/services';

interface Props {
  service: Service;
}
const { service } = Astro.props;
---
<a href={service.href} class="service-card group">
  <div class="service-media">
    <img src={service.image} alt={service.title} loading="lazy" />
    <div class="service-icon">
      <Icon name={service.icon} size={22} strokeWidth={2} />
    </div>
  </div>
  <div class="p-6 pt-9">
    <p class="eyebrow mb-3">{service.eyebrow}</p>
    <h3 class="heading-md mb-3">{service.title}</h3>
    <p class="text-muted text-sm leading-relaxed mb-4">{service.tagline}</p>
    <div class="flex items-center justify-between">
      <span class="arrow-link inline-flex">
        Mehr erfahren <Icon name="ArrowRight" size={14} strokeWidth={2.2} />
      </span>
      {service.price && (
        <span class="text-xs font-display font-bold uppercase tracking-wider text-route">{service.price}</span>
      )}
    </div>
  </div>
</a>
