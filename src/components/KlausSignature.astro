---
// Handwritten Klaus Borrmann signature SVG - used as a personal sign-off
// detail at the end of relevant pages.
interface Props {
  light?: boolean;
  size?: 'sm' | 'md' | 'lg';
}
const { light = false, size = 'md' } = Astro.props;

const w = { sm: 180, md: 260, lg: 340 }[size];
const color = light ? '#FAF7F0' : '#111111';
---
<svg width={w} viewBox="0 0 320 110" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Klaus Borrmann Unterschrift" class="signature">
  <!-- "Klaus" - flowing script -->
  <path
    d="M 18 78
       C 22 50, 26 28, 32 22
       C 36 30, 32 65, 30 78
       C 38 70, 46 58, 54 65
       C 60 72, 56 80, 58 82
       C 64 75, 72 60, 80 55
       L 78 78
       M 78 60
       C 86 55, 92 60, 90 70
       C 89 78, 84 80, 82 78
       C 80 75, 90 60, 100 56
       L 98 78"
    stroke={color} stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none"
  />
  <!-- "Borrmann" -->
  <path
    d="M 120 50
       C 126 48, 134 50, 132 60
       C 130 68, 122 70, 120 65
       C 118 55, 122 50, 124 50
       L 124 78
       M 142 60
       C 146 55, 154 55, 154 64
       C 154 72, 148 75, 144 70
       C 146 65, 152 60, 158 65
       L 156 78
       M 168 60
       C 172 55, 178 55, 178 64
       L 176 78
       C 174 70, 180 62, 186 60
       L 184 78
       M 196 55
       C 196 48, 202 50, 206 56
       C 210 60, 210 70, 206 76
       C 202 80, 196 78, 196 72
       C 196 64, 202 58, 208 62
       L 210 78
       M 220 78
       L 222 55
       C 226 52, 232 55, 230 65
       C 228 72, 234 65, 240 60
       L 242 78"
    stroke={color} stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" fill="none"
  />
  <!-- Flourish underline -->
  <path
    d="M 24 92 C 80 88, 140 90, 200 88 C 220 87, 240 90, 254 96"
    stroke={color} stroke-width="1.8" stroke-linecap="round" fill="none" opacity="0.7"
  />
  <!-- Star accent -->
  <path
    d="M 270 50 L 274 60 L 284 60 L 276 66 L 280 76 L 270 70 L 260 76 L 264 66 L 256 60 L 266 60 Z"
    fill="#B91C1C"
  />
</svg>

<style>
  .signature {
    display: block;
    stroke-dasharray: 2000;
    stroke-dashoffset: 2000;
    animation: sig-write 3s ease-out forwards;
  }
  @keyframes sig-write {
    to { stroke-dashoffset: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .signature { animation: none; stroke-dashoffset: 0; }
  }
</style>
