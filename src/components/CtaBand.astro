---
import { telLink, whatsappLink, mailWorkshopLink, site } from '../data/site';
import Icon from './Icon.astro';
import KlausSignature from './KlausSignature.astro';

interface Props {
  title?: string;
  lead?: string;
  signoff?: string;
}
const {
  title = 'Dein US-Car. Dein Klaus.',
  lead = 'Du suchst ein bestimmtes Fahrzeug und bist noch nicht fündig geworden? Du brauchst einen Spezialisten für US-Cars? Es gibt zahlreiche gute Gründe uns zu kontaktieren.',
  signoff = 'Kontaktiere uns - wir machen Deinen Fahrzeugtraum wahr. Herzliche Grüße, Dein Klaus Borrmann',
} = Astro.props;
---
<section class="section-dark section-padding relative overflow-hidden">
  <div class="absolute inset-0 z-0" aria-hidden="true">
    <img src="/images/klaus-borrmann.jpg" alt="" class="w-full h-full object-cover opacity-15 ken-burns" loading="lazy" />
    <div class="absolute inset-0" style="background: linear-gradient(90deg, rgba(8,8,8,0.96) 0%, rgba(8,8,8,0.85) 50%, rgba(8,8,8,0.7) 100%);"></div>
  </div>

  <div class="absolute -right-12 top-1/2 -translate-y-1/2 z-0 pointer-events-none opacity-[0.05]" aria-hidden="true">
    <span class="font-display text-[18rem] leading-none text-white" style="letter-spacing: -0.04em;">66</span>
  </div>

  <div class="container-r66 relative z-10">
    <div class="grid lg:grid-cols-12 gap-12 items-center">
      <div class="lg:col-span-7">
        <p class="eyebrow eyebrow-light">Kontakt</p>
        <h2 class="heading-xl text-white text-balance mb-7">{title}</h2>
        <p class="text-lg md:text-xl text-white/80 leading-relaxed mb-10 text-pretty max-w-2xl">{lead}</p>

        <div class="flex flex-wrap gap-3 mb-12">
          <a href={telLink} class="btn btn-primary btn-lg group">
            <Icon name="Phone" size={16} strokeWidth={2} />
            {site.phoneDisplay}
            <span class="hover-arrow inline-flex"><Icon name="ArrowRight" size={15} strokeWidth={2} /></span>
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg">
            <Icon name="MessageCircle" size={16} strokeWidth={2} />
            WhatsApp
          </a>
          <a href={mailWorkshopLink} class="btn btn-outline-light btn-lg">
            <Icon name="Mail" size={16} strokeWidth={2} />
            Werkstatt anschreiben
          </a>
        </div>

        <div class="flex items-end gap-6 pt-8 border-t border-white/10 max-w-lg">
          <div class="flex-shrink-0">
            <KlausSignature light size="sm" />
          </div>
          <div class="flex-1 pb-2">
            <p class="text-white/85 text-sm leading-snug italic">"{signoff}"</p>
          </div>
        </div>
      </div>

      <div class="lg:col-span-5 hidden lg:block">
        <div class="relative">
          <div class="rounded-xl overflow-hidden aspect-[4/5] bg-onyx-900 border border-white/10">
            <img src="/images/klaus-borrmann.jpg" alt="Klaus Borrmann" class="w-full h-full object-cover" loading="lazy" />
          </div>
          <div class="absolute -bottom-5 -left-5 rounded-lg px-5 py-4 max-w-[230px]" style="background: rgba(255,254,251,0.96); backdrop-filter: blur(14px); box-shadow: 0 22px 48px -16px rgba(0,0,0,0.5);">
            <p class="text-[0.66rem] text-muted uppercase tracking-widest mb-1">Direkt von</p>
            <p class="font-display text-lg font-medium text-onyx leading-tight">Klaus Borrmann</p>
            <a href={telLink} class="text-route text-sm font-medium mt-2 inline-flex items-center gap-1 hover:gap-2 transition-all">
              <Icon name="Phone" size={12} strokeWidth={2} />
              {site.phoneDisplay}
            </a>
          </div>
          <div class="absolute -top-4 -right-4 w-20 h-20 rounded-full flex flex-col items-center justify-center text-center" style="background: #B91C1C; box-shadow: 0 14px 36px -8px rgba(185,28,28,0.5);">
            <span class="font-display text-[0.55rem] text-white/85 uppercase tracking-widest">Est.</span>
            <span class="font-display text-xl font-medium text-white leading-none">1989</span>
            <span class="font-display text-[0.5rem] text-white/85 uppercase tracking-widest mt-0.5">Hamburg</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
