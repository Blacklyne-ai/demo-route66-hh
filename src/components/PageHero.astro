---
import Icon from './Icon.astro';

interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  image?: string;
  imageAlt?: string;
  cta?: { label: string; href: string; icon?: string };
  secondaryCta?: { label: string; href: string; icon?: string };
  breadcrumbs?: { label: string; href: string }[];
  variant?: 'light' | 'dark';
}
const { eyebrow, title, lead, image, imageAlt = '', cta, secondaryCta, breadcrumbs = [], variant = 'light' } = Astro.props;
---
<section class={`relative ${variant === 'dark' ? 'section-dark' : 'section-light'} pt-36 pb-16 md:pt-44 md:pb-24 overflow-hidden`}>
  <div class="container-r66 relative z-10">
    {breadcrumbs.length > 0 && (
      <nav class={`mb-8 flex items-center gap-2 text-[0.78rem] ${variant === 'dark' ? 'text-white/55' : 'text-muted'}`} aria-label="Breadcrumb">
        {breadcrumbs.map((b, i) => (
          <Fragment>
            <a href={b.href} class="hover:text-route transition">{b.label}</a>
            {i < breadcrumbs.length - 1 && <Icon name="ChevronRight" size={11} strokeWidth={2} />}
          </Fragment>
        ))}
      </nav>
    )}
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-end">
      <div class="lg:col-span-7">
        {eyebrow && <p class={`eyebrow ${variant === 'dark' ? 'eyebrow-light' : ''}`}>{eyebrow}</p>}
        <h1 class={`heading-display text-balance ${variant === 'dark' ? 'text-white' : 'text-onyx'}`}>{title}</h1>
        {lead && <p class={`mt-7 text-lg md:text-xl leading-relaxed max-w-2xl text-pretty ${variant === 'dark' ? 'text-white/80' : 'text-muted'}`}>{lead}</p>}
        {(cta || secondaryCta) && (
          <div class="mt-10 flex flex-wrap gap-3">
            {cta && (
              <a href={cta.href} class="btn btn-primary btn-lg">
                {cta.icon && <Icon name={cta.icon} size={16} strokeWidth={2} />}
                {cta.label}
                <Icon name="ArrowRight" size={15} strokeWidth={2} />
              </a>
            )}
            {secondaryCta && (
              <a href={secondaryCta.href} class={`btn ${variant === 'dark' ? 'btn-outline-light' : 'btn-outline'} btn-lg`}>
                {secondaryCta.icon && <Icon name={secondaryCta.icon} size={16} strokeWidth={2} />}
                {secondaryCta.label}
              </a>
            )}
          </div>
        )}
      </div>
      {image && (
        <div class="lg:col-span-5">
          <div class="rounded-xl overflow-hidden aspect-[4/5] lg:aspect-[3/4] bg-cream-warm">
            <img src={image} alt={imageAlt} class="w-full h-full object-cover" loading="eager" />
          </div>
        </div>
      )}
    </div>
  </div>
</section>
