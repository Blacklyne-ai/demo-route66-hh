---
// DSGVO-konformer Cookie-Banner. Diese statische Site setzt standardmäßig
// keine Tracking-Cookies - Einwilligung wird nur lokal (localStorage) protokolliert.
---
<div id="cookie-banner" class="fixed bottom-0 left-0 right-0 z-[60] p-3 md:p-4 translate-y-full transition-transform duration-500" style="will-change: transform;">
  <div class="container-r66">
    <div class="rounded-lg p-5 md:p-6 flex flex-col md:flex-row md:items-center gap-4 md:gap-6" style="background: #0A0A0A; border: 1px solid rgba(255,255,255,0.12); box-shadow: 0 24px 60px -20px rgba(0,0,0,0.6);">
      <div class="flex-1">
        <p class="text-white font-display font-bold text-sm mb-2 flex items-center gap-2 uppercase tracking-wider">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#B91C1C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="8.5" cy="10.5" r="0.6" fill="#B91C1C"/><circle cx="15" cy="9" r="0.6" fill="#B91C1C"/><circle cx="14.5" cy="15" r="0.6" fill="#B91C1C"/><circle cx="9.5" cy="15.5" r="0.6" fill="#B91C1C"/></svg>
          Datenschutz
        </p>
        <p class="text-white/65 text-[0.82rem] leading-relaxed">
          Wir nutzen notwendige Cookies um diese Site funktionsfaehig zu halten. Mit Deiner Einwilligung verwenden wir zusaetzlich Analyse-Cookies. Details in unserer <a href="/datenschutz" class="text-route hover:text-white underline underline-offset-2">Datenschutzerklärung</a>.
        </p>
      </div>
      <div class="flex gap-2.5 flex-shrink-0">
        <button id="cookie-reject" class="btn btn-outline-light btn-sm">Ablehnen</button>
        <button id="cookie-accept" class="btn btn-primary btn-sm">Alle akzeptieren</button>
      </div>
    </div>
  </div>
</div>

<script>
  const KEY = 'route66-cookie-consent';
  const banner = document.getElementById('cookie-banner');
  const show = () => banner && (banner.style.transform = 'translateY(0)');
  const hide = () => banner && (banner.style.transform = 'translateY(150%)');

  const stored = (() => { try { return localStorage.getItem(KEY); } catch { return 'dismissed'; } })();
  if (!stored) setTimeout(show, 1200);

  const set = (v: string) => { try { localStorage.setItem(KEY, v); } catch {} hide(); };
  document.getElementById('cookie-accept')?.addEventListener('click', () => set('accepted'));
  document.getElementById('cookie-reject')?.addEventListener('click', () => set('rejected'));
</script>
