---
// Slim top banner for active job posting - direkt über der Nav-Pille
// Fixed height (48px mobile / 52px desktop) so Header can sit at top-[48px]/md:top-[52px]
import Icon from './Icon.astro';
---
<a id="job-banner" href="/jobs" class="job-banner-top group" aria-label="Wir stellen ein per sofort">
  <div class="container-r66 h-full">
    <div class="flex items-center justify-center gap-2 md:gap-3 h-full text-white text-[0.74rem] md:text-[0.82rem] whitespace-nowrap overflow-hidden">
      <span class="hidden md:inline-flex items-center gap-1.5 px-2 py-0.5 rounded-md bg-white/15 text-white text-[0.6rem] font-medium uppercase tracking-widest backdrop-blur-sm flex-shrink-0">
        <Icon name="Briefcase" size={10} strokeWidth={2.4} />
        Jobs
      </span>
      <span class="font-medium tracking-wide truncate">
        Wir stellen ein per sofort: <span class="hidden sm:inline">KFZ-Mechaniker / Mechatroniker (m/w/d)</span><span class="sm:hidden">Mechaniker / Mechatroniker</span>
      </span>
      <span class="inline-flex items-center gap-1 font-medium underline underline-offset-2 decoration-white/40 group-hover:decoration-white transition-all flex-shrink-0">
        Zur Stelle
        <Icon name="ArrowRight" size={12} strokeWidth={2.4} class="hover-arrow" />
      </span>
    </div>
  </div>
</a>

<style>
  .job-banner-top {
    display: block;
    position: fixed;
    top: 0; left: 0; right: 0;
    height: 44px;
    z-index: 60;
    background: linear-gradient(90deg, #991B1B 0%, #B91C1C 50%, #DC2626 100%);
    box-shadow: 0 2px 8px -2px rgba(185, 28, 28, 0.35);
  }
  @media (min-width: 768px) {
    .job-banner-top { height: 48px; }
  }
</style>
