---
import Icon from './Icon.astro';

interface Props {
  title: string;
  embedUrl: string;
  address: string;
  directionsUrl?: string;
  phone?: string;
  phoneIntl?: string;
  email?: string;
  hours?: string[];
  dark?: boolean;
}
const { title, embedUrl, address, directionsUrl, phone, phoneIntl, email, hours = [], dark = false } = Astro.props;
---
<div class={`rounded-lg overflow-hidden ${dark ? 'card-dark' : 'card'}`}>
  <div class="aspect-[16/10] -m-7 mb-0 relative bg-onyx">
    <iframe
      src={embedUrl}
      width="100%"
      height="100%"
      style="border:0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title={`Karte ${title}`}
      class="absolute inset-0 grayscale-[20%]"
    ></iframe>
  </div>
  <div class="p-2 pt-7">
    <h3 class="heading-md mb-3">{title}</h3>
    <p class={`mb-4 text-sm leading-relaxed ${dark ? 'text-white/70' : 'text-muted'}`}>{address}</p>
    {phone && phoneIntl && (
      <a href={`tel:${phoneIntl}`} class="flex items-center gap-2 text-sm mb-2 font-semibold hover:text-route transition">
        <Icon name="Phone" size={14} strokeWidth={2.2} class="text-route" />{phone}
      </a>
    )}
    {email && (
      <a href={`mailto:${email}`} class={`flex items-center gap-2 text-sm mb-2 font-medium hover:text-route transition ${dark ? 'text-white/85' : 'text-onyx'}`}>
        <Icon name="Mail" size={14} strokeWidth={2.2} class="text-route" />{email}
      </a>
    )}
    {hours.length > 0 && (
      <ul class={`mt-3 space-y-1 text-sm ${dark ? 'text-white/70' : 'text-muted'}`}>
        {hours.map((h) => <li>{h}</li>)}
      </ul>
    )}
    {directionsUrl && (
      <a href={directionsUrl} target="_blank" rel="noopener" class="arrow-link mt-5 inline-flex">
        Route planen <Icon name="Navigation" size={14} strokeWidth={2.2} />
      </a>
    )}
  </div>
</div>
