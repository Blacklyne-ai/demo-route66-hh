---
import Icon from './Icon.astro';

interface Props {
  title: string;
  embedUrl: string;
  address: string;
  directionsUrl?: string;
  phone?: string;
  phoneIntl?: string;
  email?: string;
  hours?: string[];
}
const { title, embedUrl, address, directionsUrl, phone, phoneIntl, email, hours = [] } = Astro.props;
---
<div class="rounded-lg overflow-hidden border border-line bg-white">
  <div class="aspect-[16/9] relative bg-cream-warm">
    <iframe
      src={embedUrl}
      width="100%"
      height="100%"
      style="border:0"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title={`Karte ${title}`}
      class="absolute inset-0"
    ></iframe>
  </div>
  <div class="p-7">
    <h3 class="heading-md mb-3">{title}</h3>
    <p class="text-muted leading-relaxed mb-5">{address}</p>
    {phone && phoneIntl && (
      <a href={`tel:${phoneIntl}`} class="flex items-center gap-2 mb-2 text-onyx font-medium hover:text-route transition">
        <Icon name="Phone" size={14} strokeWidth={2} class="text-route" />{phone}
      </a>
    )}
    {email && (
      <a href={`mailto:${email}`} class="flex items-center gap-2 mb-2 text-muted hover:text-route transition">
        <Icon name="Mail" size={14} strokeWidth={2} class="text-route" />{email}
      </a>
    )}
    {hours.length > 0 && (
      <ul class="mt-4 space-y-1 text-sm text-muted">
        {hours.map((h) => <li>{h}</li>)}
      </ul>
    )}
    {directionsUrl && (
      <a href={directionsUrl} target="_blank" rel="noopener" class="arrow-link mt-6 inline-flex">
        Route planen <Icon name="Navigation" size={13} strokeWidth={2} />
      </a>
    )}
  </div>
</div>
