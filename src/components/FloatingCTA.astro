---
import { telLink, whatsappLink, site } from '../data/site';
import Icon from './Icon.astro';
---
<div class="floating-mobile fixed bottom-4 left-4 right-4 z-40 gap-2 pointer-events-none">
  <a href={telLink} class="btn btn-primary pointer-events-auto flex-1 !gap-2" style="padding: 0.95rem;" aria-label={`Anrufen ${site.phoneDisplay}`}>
    <Icon name="Phone" size={15} strokeWidth={2} />
    <span class="text-[0.8rem] font-medium">{site.phoneDisplay}</span>
  </a>
  <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp pointer-events-auto !px-4" style="padding-top:0.95rem;padding-bottom:0.95rem;" aria-label="WhatsApp">
    <Icon name="MessageCircle" size={18} strokeWidth={2} />
  </a>
</div>
