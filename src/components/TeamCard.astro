---
import Icon from './Icon.astro';
import type { TeamMember } from '../data/team';

interface Props {
  member: TeamMember;
  index?: number;
}
const { member, index = 0 } = Astro.props;

// Years of experience approximation per member (for the badge)
const yearsBadge: Record<string, string> = {
  'klaus-borrmann': '35+',
  'michel-schmidt': '40',
  'fred-fiedler': '30',
  'bjoern': 'V8',
};
const years = yearsBadge[member.slug] ?? '';
---
<article class="team-card group">
  <div class="team-media">
    <img src={member.image} alt={member.name} loading="lazy" />
    <div class="team-veil"></div>

    <!-- Index Number top-left -->
    <span class="team-num">{String(index + 1).padStart(2, '0')}</span>

    <!-- Years Badge top-right -->
    {years && (
      <span class="team-years">
        <span class="team-years-num">{years}</span>
        <span class="team-years-label">{member.slug === 'bjoern' ? 'im Herzen' : 'Jahre'}</span>
      </span>
    )}

    <!-- Location pill bottom-left (visible on rest) -->
    <span class="team-loc">
      <Icon name="MapPin" size={11} strokeWidth={2} />
      {member.location === 'hamburg' ? 'Hamburg' : 'Rendsburg'}
    </span>

    <!-- Bio reveal on hover -->
    <div class="team-reveal">
      <p class="text-white text-sm leading-relaxed mb-4">{member.bio}</p>
      {member.trustBadges && (
        <div class="flex flex-wrap gap-1.5">
          {member.trustBadges.map((b) => (
            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[0.6rem] font-medium uppercase tracking-wider bg-white/15 text-white border border-white/25 backdrop-blur-sm">{b}</span>
          ))}
        </div>
      )}
    </div>
  </div>
  <div class="mt-5 flex items-start justify-between gap-3">
    <div class="flex-1 min-w-0">
      <h3 class="heading-md leading-tight">{member.name}</h3>
      <p class="text-route text-sm font-medium mt-1">{member.role}</p>
    </div>
    <span class="team-arrow">
      <Icon name="ArrowUpRight" size={14} strokeWidth={2} />
    </span>
  </div>
</article>

<style>
  .team-card { cursor: default; }
  .team-media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 16px;
    background: rgb(245 240 229);
  }
  .team-media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.85s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .team-card:hover .team-media img { transform: scale(1.06); }

  .team-veil {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 25%, rgba(17, 17, 17, 0.55) 65%, rgba(17, 17, 17, 0.96) 100%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  .team-card:hover .team-veil { opacity: 1; }

  .team-num {
    position: absolute; top: 1rem; left: 1rem;
    font-family: "Oswald", sans-serif;
    font-size: 0.66rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.92);
    letter-spacing: 0.18em;
    padding: 0.35rem 0.65rem;
    border-radius: 6px;
    background: rgba(0, 0, 0, 0.45);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.16);
    transition: opacity 0.3s ease;
  }
  .team-card:hover .team-num { opacity: 0; }

  .team-years {
    position: absolute; top: 1rem; right: 1rem;
    display: inline-flex; flex-direction: column; align-items: center;
    padding: 0.45rem 0.7rem;
    border-radius: 999px;
    background: rgb(185 28 28);
    color: #fff;
    line-height: 1;
    box-shadow: 0 12px 24px -8px rgba(185, 28, 28, 0.5);
  }
  .team-years-num {
    font-family: "Oswald", sans-serif;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .team-years-label {
    font-size: 0.5rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.9;
    margin-top: 0.1rem;
  }

  .team-loc {
    position: absolute; bottom: 1rem; left: 1rem;
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    border-radius: 999px;
    background: rgba(255, 254, 251, 0.94);
    backdrop-filter: blur(8px);
    color: rgb(17 17 17);
    font-size: 0.68rem; font-weight: 500;
    transition: opacity 0.3s ease;
  }
  .team-card:hover .team-loc { opacity: 0; }

  .team-reveal {
    position: absolute;
    left: 1.25rem; right: 1.25rem; bottom: 1.25rem;
    transform: translateY(20px);
    opacity: 0;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.45s ease;
    pointer-events: none;
  }
  .team-card:hover .team-reveal { transform: translateY(0); opacity: 1; }

  .team-arrow {
    width: 36px; height: 36px;
    border-radius: 999px;
    border: 1px solid rgb(229 219 205);
    color: rgba(17, 17, 17, 0.4);
    display: inline-flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background 0.3s ease, color 0.3s ease, border-color 0.3s ease, transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .team-card:hover .team-arrow {
    border-color: rgb(185 28 28);
    background: rgb(185 28 28);
    color: #fff;
    transform: rotate(45deg) scale(1.05);
  }
</style>
