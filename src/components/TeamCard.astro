---
import Icon from './Icon.astro';
import type { TeamMember } from '../data/team';

interface Props {
  member: TeamMember;
}
const { member } = Astro.props;
---
<article class="group rounded-lg overflow-hidden bg-white border border-line transition-all duration-500 hover:-translate-y-1 hover:border-route/60 hover:shadow-xl">
  <div class="aspect-[3/4] overflow-hidden bg-onyx relative">
    <img src={member.image} alt={member.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
    <div class="absolute inset-0 bg-gradient-to-t from-onyx/95 via-onyx/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-5">
      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-md text-[0.66rem] font-display font-bold uppercase tracking-wider bg-route text-white mb-2">
        <Icon name="MapPin" size={10} strokeWidth={2.4} />
        {member.location === 'hamburg' ? 'Hamburg' : 'Rendsburg'}
      </span>
      <h3 class="heading-md text-white">{member.name}</h3>
      <p class="text-white/75 text-sm mt-1 font-medium">{member.role}</p>
    </div>
  </div>
  <div class="p-6">
    <p class="text-muted text-sm leading-relaxed mb-4">{member.bio}</p>
    {member.trustBadges && (
      <div class="flex flex-wrap gap-1.5">
        {member.trustBadges.map((b) => (
          <span class="inline-flex items-center px-2 py-1 rounded text-[0.65rem] font-display font-semibold uppercase tracking-wider bg-cream-warm border border-line text-onyx">{b}</span>
        ))}
      </div>
    )}
  </div>
</article>
