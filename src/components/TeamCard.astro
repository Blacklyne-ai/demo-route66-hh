---
import Icon from './Icon.astro';
import type { TeamMember } from '../data/team';

interface Props {
  member: TeamMember;
}
const { member } = Astro.props;
---
<article class="team-card group">
  <div class="team-media">
    <img src={member.image} alt={member.name} loading="lazy" />
    <div class="team-veil"></div>
    <div class="team-reveal">
      <p class="text-white text-sm leading-relaxed">{member.bio}</p>
      {member.trustBadges && (
        <div class="flex flex-wrap gap-2 mt-4">
          {member.trustBadges.map((b) => (
            <span class="inline-flex items-center px-2.5 py-1 rounded-md text-[0.65rem] font-medium uppercase tracking-wider bg-white/12 text-white border border-white/20">{b}</span>
          ))}
        </div>
      )}
    </div>
    <span class="team-loc">
      <Icon name="MapPin" size={11} strokeWidth={2} />
      {member.location === 'hamburg' ? 'Hamburg' : 'Rendsburg'}
    </span>
  </div>
  <div class="mt-5 flex items-start justify-between gap-3">
    <div>
      <h3 class="heading-md leading-tight">{member.name}</h3>
      <p class="text-route text-sm font-medium mt-1">{member.role}</p>
    </div>
    <span class="w-9 h-9 rounded-full border border-line text-onyx/40 inline-flex items-center justify-center group-hover:border-route group-hover:text-route group-hover:rotate-45 transition-all duration-300 flex-shrink-0">
      <Icon name="ArrowUpRight" size={14} strokeWidth={2} />
    </span>
  </div>
</article>

<style>
  .team-card { cursor: default; }
  .team-media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 14px;
    background: rgb(245 240 229);
  }
  .team-media img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .team-card:hover .team-media img { transform: scale(1.05); }

  .team-veil {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, transparent 30%, rgb(17 17 17 / 0.5) 70%, rgb(17 17 17 / 0.95) 100%);
    opacity: 0;
    transition: opacity 0.5s ease;
    pointer-events: none;
  }
  .team-card:hover .team-veil { opacity: 1; }

  .team-reveal {
    position: absolute;
    left: 1.25rem; right: 1.25rem; bottom: 1.25rem;
    transform: translateY(18px);
    opacity: 0;
    transition: transform 0.55s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.45s ease;
    pointer-events: none;
  }
  .team-card:hover .team-reveal { transform: translateY(0); opacity: 1; }

  .team-loc {
    position: absolute; top: 1rem; left: 1rem;
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.35rem 0.7rem; border-radius: 999px;
    background: rgb(255 255 255 / 0.92);
    backdrop-filter: blur(6px);
    color: rgb(17 17 17);
    font-size: 0.7rem; font-weight: 500;
    transition: opacity 0.3s ease;
  }
  .team-card:hover .team-loc { opacity: 0; }
</style>
