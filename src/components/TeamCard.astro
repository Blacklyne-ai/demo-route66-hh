---
import Icon from './Icon.astro';
import type { TeamMember } from '../data/team';

interface Props {
  member: TeamMember;
}
const { member } = Astro.props;
---
<article class="group">
  <div class="rounded-lg overflow-hidden aspect-[4/5] bg-cream-warm mb-5">
    <img src={member.image} alt={member.name} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" loading="lazy" />
  </div>
  <div class="flex items-start justify-between gap-3 mb-2">
    <h3 class="heading-md">{member.name}</h3>
    <span class="inline-flex items-center gap-1 text-[0.7rem] text-muted">
      <Icon name="MapPin" size={11} strokeWidth={2} />
      {member.location === 'hamburg' ? 'Hamburg' : 'Rendsburg'}
    </span>
  </div>
  <p class="text-route text-sm font-medium mb-3">{member.role}</p>
  <p class="text-muted text-sm leading-relaxed">{member.bio}</p>
</article>
