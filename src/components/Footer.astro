---
import { site, telLink, telRendsburgLink, mailLink, mailWorkshopLink, whatsappLink, legalNav } from '../data/site';
import { services } from '../data/services';
import Icon from './Icon.astro';
const year = new Date().getFullYear();

const company = [
  { href: '/team', label: 'Team' },
  { href: '/jobs', label: 'Jobs' },
  { href: '/presse', label: 'Presse' },
  { href: '/galerie', label: 'Galerie' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<footer class="section-dark text-white/70 pt-20 pb-8 relative overflow-hidden">
  <div class="container-r66 relative">
    <div class="grid md:grid-cols-12 gap-10 pb-12 border-b border-white/10">
      <!-- Brand -->
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-3 mb-5" aria-label="Route 66 Borrmann Motors KG">
          <img src="/images/route66-logo.png" alt="Route 66 Borrmann Motors KG" width="180" height="180" class="h-14 w-auto" style="filter: brightness(1.05);" />
          <span class="flex flex-col leading-tight">
            <span class="font-display text-lg font-bold uppercase tracking-wider text-white leading-none">Route 66</span>
            <span class="font-display text-[0.7rem] font-medium uppercase tracking-[0.18em] text-white/60 leading-none mt-1">Borrmann Motors KG</span>
          </span>
        </a>
        <p class="text-sm text-white/55 leading-relaxed max-w-xs mb-5">
          Dein Spezialist fuer US-Cars, Classic Cars, Oldtimer, Youngtimer und Neuwagen. KFZ-Meisterbetrieb in Hamburg-Bahrenfeld. Bekannt aus Cash fuer Chrom. EST. 1989.
        </p>
        <div class="flex flex-wrap gap-2">
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="w-10 h-10 rounded inline-flex items-center justify-center border border-white/12 text-white/75 hover:text-white hover:border-route transition" style="background: rgba(255,255,255,0.04);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="w-10 h-10 rounded inline-flex items-center justify-center border border-white/12 text-white/75 hover:text-white hover:border-route transition" style="background: rgba(255,255,255,0.04);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.5-4.5-10-10-10S2 6.5 2 12c0 5 3.7 9.1 8.4 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.3v7c4.6-.8 8.4-4.9 8.4-9.9z"/></svg>
          </a>
          <a href={site.social.youtube} target="_blank" rel="noopener" aria-label="YouTube" class="w-10 h-10 rounded inline-flex items-center justify-center border border-white/12 text-white/75 hover:text-white hover:border-route transition" style="background: rgba(255,255,255,0.04);">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2c-.3-1-1-1.8-2-2.1C19.6 3.5 12 3.5 12 3.5s-7.6 0-9.5.6c-1 .3-1.7 1.1-2 2.1C0 8.1 0 12 0 12s0 3.9.5 5.8c.3 1 1 1.8 2 2.1 1.9.6 9.5.6 9.5.6s7.6 0 9.5-.6c1-.3 1.7-1.1 2-2.1.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener" aria-label="WhatsApp" class="w-10 h-10 rounded inline-flex items-center justify-center border border-white/12 text-white/75 hover:text-white hover:border-route transition" style="background: rgba(255,255,255,0.04);">
            <Icon name="MessageCircle" size={17} />
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="md:col-span-3">
        <h3 class="text-white font-display mb-4 text-[0.72rem] tracking-[0.18em] uppercase font-bold">Services</h3>
        <ul class="space-y-2.5 text-sm">
          {services.map((s) => (<li><a href={s.href} class="nav-link">{s.title}</a></li>))}
          <li><a href={site.external.autoscout24} target="_blank" rel="noopener" class="nav-link inline-flex items-center gap-1">Aktuelle Fahrzeuge <Icon name="ExternalLink" size={11} strokeWidth={2.2} /></a></li>
          <li><a href={site.external.partsShop} target="_blank" rel="noopener" class="nav-link inline-flex items-center gap-1">Ersatzteile-Shop <Icon name="ExternalLink" size={11} strokeWidth={2.2} /></a></li>
        </ul>
      </div>

      <!-- Company -->
      <div class="md:col-span-2">
        <h3 class="text-white font-display mb-4 text-[0.72rem] tracking-[0.18em] uppercase font-bold">Borrmann Motors</h3>
        <ul class="space-y-2.5 text-sm">
          {company.map((i) => (<li><a href={i.href} class="nav-link">{i.label}</a></li>))}
          {legalNav.map((i) => (<li><a href={i.href} class="nav-link">{i.label}</a></li>))}
        </ul>
      </div>

      <!-- Visit -->
      <div class="md:col-span-3">
        <h3 class="text-white font-display mb-4 text-[0.72rem] tracking-[0.18em] uppercase font-bold">Hamburg HQ</h3>
        <address class="not-italic text-sm text-white/55 leading-relaxed mb-3">
          {site.address.street}<br />
          {site.address.streetDetail}<br />
          {site.address.postal} {site.address.city}
        </address>
        <ul class="space-y-2 text-sm mb-4">
          <li class="flex items-center gap-2"><Icon name="Phone" size={13} class="text-route" /><a href={telLink} class="text-white hover:text-route transition font-medium">{site.phoneDisplay}</a></li>
          <li class="flex items-start gap-2"><Icon name="Mail" size={13} class="text-route mt-1" /><a href={mailLink} class="text-white/65 hover:text-route transition break-all">{site.email}</a></li>
          <li class="flex items-start gap-2"><Icon name="Wrench" size={13} class="text-route mt-1" /><a href={mailWorkshopLink} class="text-white/65 hover:text-route transition break-all">{site.emailWorkshop}</a></li>
        </ul>
        <p class="text-sm text-white/55 leading-relaxed">
          Mo - Do: 8 - 17 Uhr<br />
          Fr: 8 - 15 Uhr<br />
          Sa: Nach Vereinbarung
        </p>

        <h3 class="text-white font-display mt-6 mb-3 text-[0.72rem] tracking-[0.18em] uppercase font-bold">Zweigstelle Rendsburg</h3>
        <address class="not-italic text-sm text-white/55 leading-relaxed mb-2">
          {site.addressRendsburg.street}<br />
          {site.addressRendsburg.postal} {site.addressRendsburg.city}
        </address>
        <a href={telRendsburgLink} class="text-white hover:text-route transition text-sm font-medium block">{site.phoneRendsburgDisplay}</a>
      </div>
    </div>

    <div class="pt-6 flex flex-col md:flex-row md:justify-between gap-3 text-xs text-white/45">
      <p>(c) {year} {site.legalName} - {site.legal.gerichtsstand} {site.legal.hra} - USt-IdNr. {site.legal.ustIdNr}</p>
      <div class="flex flex-wrap gap-5">
        {legalNav.map((i) => (<a href={i.href} class="hover:text-route transition">{i.label}</a>))}
        <span>Hamburg-Bahrenfeld - Bekannt aus Cash fuer Chrom DMAX - EST. 1989</span>
      </div>
    </div>
  </div>
</footer>
