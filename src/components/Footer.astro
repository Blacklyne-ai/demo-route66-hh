---
import { site, telLink, telRendsburgLink, mailLink, mailWorkshopLink, whatsappLink, legalNav } from '../data/site';
import { services } from '../data/services';
import Icon from './Icon.astro';
const year = new Date().getFullYear();

const company = [
  { href: '/team', label: 'Team' },
  { href: '/galerie', label: 'Galerie' },
  { href: '/presse', label: 'Presse' },
  { href: '/jobs', label: 'Jobs' },
  { href: '/kontakt', label: 'Kontakt' },
];

const shops = [
  { href: site.external.autoscout24, label: 'Cars for Sale (AutoScout24)' },
  { href: site.external.partsShop, label: 'Shop - Merchandise' },
  { href: site.external.shopErsatzteile, label: 'Shop - Ersatzteile' },
  { href: site.external.shopTuning, label: 'Shop - Tuning' },
];
---

<footer class="section-dark relative overflow-hidden">
  <!-- Subtle dark grid pattern -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" aria-hidden="true" style="background-image: linear-gradient(rgba(255,255,255,0.5) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.5) 1px, transparent 1px); background-size: 80px 80px;"></div>

  <!-- Top: Brand Badges Strip -->
  <div class="border-b border-white/10 py-12 relative z-10">
    <div class="container-r66">
      <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8 items-center">
        <!-- Logo -->
        <a href="/" class="inline-flex items-center gap-3" aria-label="Route 66 Borrmann Motors KG">
          <img src="/images/route66-logo.png" alt="Route 66 Borrmann Motors KG" width="180" height="180" class="h-14 w-auto" style="filter: brightness(1.05);" />
          <span class="flex flex-col leading-tight">
            <span class="font-display text-lg font-medium text-white leading-none">Route 66</span>
            <span class="text-[0.7rem] text-white/55 leading-none mt-1">Borrmann Motors KG</span>
          </span>
        </a>

        <!-- Shelby Cobra Partner Badge -->
        <div class="flex items-center gap-4 py-3 px-4 rounded-xl" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);">
          <div class="w-12 h-12 rounded-lg bg-white flex items-center justify-center flex-shrink-0">
            <img src="/images/shelby-circle-snake.png" alt="Shelby" class="w-9 h-9 object-contain" />
          </div>
          <div>
            <p class="text-[0.62rem] tracking-[0.16em] uppercase text-white/55 leading-none">Official</p>
            <p class="font-display text-sm font-medium text-white leading-tight mt-1">Shelby Service Partner</p>
          </div>
        </div>

        <!-- DMAX Cash für Chrom Badge -->
        <div class="flex items-center gap-4 py-3 px-4 rounded-xl" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);">
          <span class="w-12 h-12 rounded-lg bg-route inline-flex items-center justify-center flex-shrink-0">
            <Icon name="Tv" size={20} strokeWidth={2} class="text-white" />
          </span>
          <div>
            <p class="text-[0.62rem] tracking-[0.16em] uppercase text-white/55 leading-none">Bekannt aus</p>
            <p class="font-display text-sm font-medium text-white leading-tight mt-1">Cash für Chrom · DMAX</p>
          </div>
        </div>

        <!-- EST. 1989 Badge -->
        <div class="flex items-center gap-4 py-3 px-4 rounded-xl" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.10);">
          <span class="w-12 h-12 rounded-lg inline-flex items-center justify-center flex-shrink-0" style="background: rgba(185,28,28,0.15); border: 1px solid rgba(185,28,28,0.3);">
            <Icon name="Award" size={20} strokeWidth={1.8} class="text-route" />
          </span>
          <div>
            <p class="text-[0.62rem] tracking-[0.16em] uppercase text-white/55 leading-none">KFZ-Meisterbetrieb</p>
            <p class="font-display text-sm font-medium text-white leading-tight mt-1">EST. 1989 - Hamburg</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Footer Grid -->
  <div class="container-r66 relative z-10 pt-16 pb-10">
    <div class="grid md:grid-cols-12 gap-10 lg:gap-14 pb-14 border-b border-white/10">
      <!-- About Column -->
      <div class="md:col-span-4">
        <p class="text-white/65 leading-relaxed mb-7">
          US-Cars, Classic Cars, Oldtimer und Youngtimer. Import, Verkauf und Service-Werkstatt in Hamburg-Bahrenfeld. Zweigstelle in Rendsburg. KFZ-Meisterbetrieb seit 1989.
        </p>
        <div class="flex flex-wrap gap-2.5">
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="footer-social">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="footer-social">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.5-4.5-10-10-10S2 6.5 2 12c0 5 3.7 9.1 8.4 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.3v7c4.6-.8 8.4-4.9 8.4-9.9z"/></svg>
          </a>
          <a href={site.social.youtube} target="_blank" rel="noopener" aria-label="YouTube" class="footer-social">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2c-.3-1-1-1.8-2-2.1C19.6 3.5 12 3.5 12 3.5s-7.6 0-9.5.6c-1 .3-1.7 1.1-2 2.1C0 8.1 0 12 0 12s0 3.9.5 5.8c.3 1 1 1.8 2 2.1 1.9.6 9.5.6 9.5.6s7.6 0 9.5-.6c1-.3 1.7-1.1 2-2.1.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener" aria-label="WhatsApp" class="footer-social">
            <Icon name="MessageCircle" size={16} />
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="md:col-span-2">
        <h3 class="text-white text-xs font-medium uppercase tracking-[0.18em] mb-5">Services</h3>
        <ul class="space-y-3">
          {services.map((s) => (<li><a href={s.href} class="nav-link-footer">{s.title}</a></li>))}
        </ul>
      </div>

      <!-- Shops + External -->
      <div class="md:col-span-2">
        <h3 class="text-white text-xs font-medium uppercase tracking-[0.18em] mb-5">Shops & Verkauf</h3>
        <ul class="space-y-3">
          {shops.map((s) => (
            <li>
              <a href={s.href} target="_blank" rel="noopener" class="nav-link-footer inline-flex items-center gap-1.5">
                <span>{s.label}</span>
                <Icon name="ExternalLink" size={10} strokeWidth={2} />
              </a>
            </li>
          ))}
        </ul>

        <h3 class="text-white text-xs font-medium uppercase tracking-[0.18em] mb-5 mt-7">Über uns</h3>
        <ul class="space-y-3">
          {company.map((i) => (<li><a href={i.href} class="nav-link-footer">{i.label}</a></li>))}
        </ul>
      </div>

      <!-- Standort Karte mit Live-Status -->
      <div class="md:col-span-4">
        <div class="rounded-xl p-6 mb-4" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
          <div class="flex items-start justify-between gap-3 mb-5">
            <div>
              <p class="text-[0.66rem] tracking-[0.18em] uppercase text-route font-medium mb-1">Hauptstandort</p>
              <h3 class="font-display text-lg font-medium text-white leading-tight">Hamburg-Bahrenfeld</h3>
            </div>
          </div>
          <address class="not-italic text-white/65 leading-relaxed mb-5 text-sm">
            {site.address.street}<br />
            {site.address.streetDetail}<br />
            {site.address.postal} {site.address.city}
          </address>
          <ul class="space-y-2.5 text-sm mb-5">
            <li><a href={telLink} class="text-white hover:text-route transition inline-flex items-center gap-2"><Icon name="Phone" size={13} class="text-route" />{site.phoneDisplay}</a></li>
            <li><a href={mailLink} class="text-white/65 hover:text-route transition inline-flex items-center gap-2 break-all"><Icon name="Mail" size={13} class="text-route" />{site.email}</a></li>
            <li><a href={mailWorkshopLink} class="text-white/65 hover:text-route transition inline-flex items-center gap-2 break-all"><Icon name="Wrench" size={13} class="text-route" />{site.emailWorkshop}</a></li>
          </ul>
          <p class="text-white/55 text-[0.78rem] leading-relaxed pt-4 border-t border-white/10">
            Mo - Do: 8 - 17 Uhr · Fr: 8 - 15 Uhr<br />
            Sa: Nach Vereinbarung
          </p>
        </div>

        <div class="rounded-xl p-5" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
          <p class="text-[0.62rem] tracking-[0.18em] uppercase text-route font-medium mb-1">Zweigstelle</p>
          <h3 class="font-display text-base font-medium text-white leading-tight mb-2">Rendsburg</h3>
          <p class="text-white/55 text-xs leading-relaxed mb-2">{site.addressRendsburg.street}, {site.addressRendsburg.postal} {site.addressRendsburg.city}</p>
          <a href={telRendsburgLink} class="text-white text-sm hover:text-route transition inline-flex items-center gap-2"><Icon name="Phone" size={12} class="text-route" />{site.phoneRendsburgDisplay}</a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 flex flex-col md:flex-row md:justify-between gap-4 text-xs text-white/45">
      <p>(c) {year} {site.legalName} · {site.legal.hra} · USt-IdNr. {site.legal.ustIdNr}</p>
      <div class="flex flex-wrap gap-5">
        {legalNav.map((i) => (<a href={i.href} class="hover:text-white transition">{i.label}</a>))}
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-social {
    width: 40px; height: 40px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.7);
    display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }
  .footer-social:hover {
    background: rgb(185 28 28);
    border-color: rgb(185 28 28);
    color: #fff;
    transform: translateY(-2px);
  }
</style>
