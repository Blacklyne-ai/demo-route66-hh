---
import { site, telLink, telRendsburgLink, mailLink, mailWorkshopLink, whatsappLink, legalNav } from '../data/site';
import { services } from '../data/services';
import Icon from './Icon.astro';
import Route66Shield from './Route66Shield.astro';
const year = new Date().getFullYear();

const company = [
  { href: '/team', label: 'Team' },
  { href: '/jobs', label: 'Jobs' },
  { href: '/presse', label: 'Presse' },
  { href: '/galerie', label: 'Galerie' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<footer class="section-dark relative overflow-hidden">
  <!-- Decorative Route 66 Shield -->
  <div class="absolute -right-20 -top-20 pointer-events-none" aria-hidden="true">
    <Route66Shield class="text-white" size={520} opacity={0.04} />
  </div>
  <!-- Decorative big 66 -->
  <span class="absolute -left-12 -bottom-32 font-display text-[24rem] leading-none text-white/[0.025] pointer-events-none select-none hidden md:block" aria-hidden="true">66</span>

  <!-- Top Banner: Klaus' Final Sign-Off -->
  <div class="border-b border-white/10 py-14 relative z-10">
    <div class="container-r66">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
        <div class="lg:col-span-7">
          <p class="eyebrow eyebrow-light">Ein letzter Gedanke</p>
          <p class="font-display text-2xl md:text-3xl text-white leading-snug mt-3 mb-5">
            "V8 ist Religion. Und ich bin der Pastor."
          </p>
          <div class="flex items-center gap-3">
            <div class="w-11 h-11 rounded-full overflow-hidden flex-shrink-0">
              <img src="/images/klaus-borrmann.jpg" alt="Klaus" class="w-full h-full object-cover" />
            </div>
            <div>
              <p class="font-display text-white font-medium leading-tight">Klaus Borrmann</p>
              <p class="text-white/55 text-[0.7rem] uppercase tracking-widest mt-1">Inhaber - seit 1989</p>
            </div>
          </div>
        </div>
        <div class="lg:col-span-5 flex flex-col gap-3">
          <a href={telLink} class="btn btn-primary btn-lg group !rounded-full">
            <Icon name="Phone" size={16} strokeWidth={2} />
            {site.phoneDisplay}
            <span class="hover-arrow inline-flex"><Icon name="ArrowRight" size={15} strokeWidth={2} /></span>
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener" class="btn btn-whatsapp btn-lg !rounded-full">
            <Icon name="MessageCircle" size={16} strokeWidth={2} />
            WhatsApp schreiben
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Main Footer -->
  <div class="container-r66 relative z-10 pt-16 pb-10">
    <div class="grid md:grid-cols-12 gap-12 pb-14 border-b border-white/10">
      <!-- Brand Column -->
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-3 mb-6" aria-label="Route 66 Borrmann Motors KG">
          <img src="/images/route66-logo.png" alt="Route 66 Borrmann Motors KG" width="180" height="180" class="h-14 w-auto" style="filter: brightness(1.05);" />
          <span class="flex flex-col leading-tight">
            <span class="font-display text-lg font-medium text-white leading-none">Route 66</span>
            <span class="text-[0.72rem] text-white/55 leading-none mt-1">Borrmann Motors KG</span>
          </span>
        </a>
        <p class="text-white/60 leading-relaxed max-w-sm mb-7">
          US-Cars, Classic Cars, Oldtimer und Youngtimer. KFZ-Meisterbetrieb in Hamburg-Bahrenfeld. Bekannt aus Cash für Chrom. EST. 1989.
        </p>

        <!-- Mini-Stats -->
        <div class="grid grid-cols-3 gap-4 mb-7 max-w-sm">
          <div>
            <p class="font-display text-2xl text-white font-medium leading-none">35+</p>
            <p class="text-white/55 text-[0.62rem] uppercase tracking-widest mt-2">Jahre</p>
          </div>
          <div>
            <p class="font-display text-2xl text-white font-medium leading-none">110+</p>
            <p class="text-white/55 text-[0.62rem] uppercase tracking-widest mt-2">Team-Jahre</p>
          </div>
          <div>
            <p class="font-display text-2xl text-white font-medium leading-none">4.9★</p>
            <p class="text-white/55 text-[0.62rem] uppercase tracking-widest mt-2">Google</p>
          </div>
        </div>

        <!-- Social Icons -->
        <div class="flex flex-wrap gap-2.5">
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="footer-social">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="footer-social">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.5-4.5-10-10-10S2 6.5 2 12c0 5 3.7 9.1 8.4 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.3v7c4.6-.8 8.4-4.9 8.4-9.9z"/></svg>
          </a>
          <a href={site.social.youtube} target="_blank" rel="noopener" aria-label="YouTube" class="footer-social">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2c-.3-1-1-1.8-2-2.1C19.6 3.5 12 3.5 12 3.5s-7.6 0-9.5.6c-1 .3-1.7 1.1-2 2.1C0 8.1 0 12 0 12s0 3.9.5 5.8c.3 1 1 1.8 2 2.1 1.9.6 9.5.6 9.5.6s7.6 0 9.5-.6c1-.3 1.7-1.1 2-2.1.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener" aria-label="WhatsApp" class="footer-social">
            <Icon name="MessageCircle" size={16} />
          </a>
          <a href={site.external.autoscout24} target="_blank" rel="noopener" aria-label="AutoScout24" class="footer-social-text">
            AutoScout24 →
          </a>
        </div>
      </div>

      <!-- Services -->
      <div class="md:col-span-2">
        <h3 class="text-white text-sm font-medium mb-5">Services</h3>
        <ul class="space-y-3">
          {services.map((s) => (<li><a href={s.href} class="nav-link-footer">{s.title}</a></li>))}
        </ul>
      </div>

      <!-- Borrmann Motors -->
      <div class="md:col-span-2">
        <h3 class="text-white text-sm font-medium mb-5">Borrmann Motors</h3>
        <ul class="space-y-3">
          {company.map((i) => (<li><a href={i.href} class="nav-link-footer">{i.label}</a></li>))}
          {legalNav.map((i) => (<li><a href={i.href} class="nav-link-footer">{i.label}</a></li>))}
        </ul>
      </div>

      <!-- Standort + Hours -->
      <div class="md:col-span-4">
        <div class="rounded-xl p-6" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
          <div class="flex items-start justify-between gap-3 mb-5">
            <div>
              <p class="text-[0.66rem] tracking-[0.18em] uppercase text-route font-medium mb-1">Hauptstandort</p>
              <h3 class="font-display text-lg font-medium text-white leading-tight">Hamburg-Bahrenfeld</h3>
            </div>
            <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[0.6rem] font-medium uppercase tracking-widest" style="background: rgba(16,185,129,0.15); color: rgb(52 211 153); border: 1px solid rgba(16,185,129,0.3);">
              <span class="w-1.5 h-1.5 rounded-full bg-green-400" style="background: rgb(52 211 153);"></span>
              Mo-Do offen
            </span>
          </div>
          <address class="not-italic text-white/65 leading-relaxed mb-4 text-sm">
            {site.address.street}<br />
            {site.address.streetDetail}<br />
            {site.address.postal} {site.address.city}
          </address>
          <ul class="space-y-2 text-sm mb-5">
            <li><a href={telLink} class="text-white hover:text-route transition inline-flex items-center gap-2"><Icon name="Phone" size={13} class="text-route" />{site.phoneDisplay}</a></li>
            <li><a href={mailLink} class="text-white/65 hover:text-route transition inline-flex items-center gap-2"><Icon name="Mail" size={13} class="text-route" />{site.email}</a></li>
          </ul>
          <p class="text-white/55 text-[0.78rem] leading-relaxed pt-4 border-t border-white/10">
            Mo - Do: 8 - 17 Uhr · Fr: 8 - 15 Uhr<br />
            Sa: Nach Vereinbarung
          </p>
        </div>

        <div class="mt-4 rounded-xl p-5" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);">
          <div class="flex items-start justify-between gap-3 mb-2">
            <div>
              <p class="text-[0.62rem] tracking-[0.18em] uppercase text-route font-medium mb-1">Zweigstelle</p>
              <h3 class="font-display text-base font-medium text-white leading-tight">Rendsburg - Björn</h3>
            </div>
          </div>
          <p class="text-white/55 text-xs leading-relaxed mb-2">{site.addressRendsburg.street}, {site.addressRendsburg.postal} {site.addressRendsburg.city}</p>
          <a href={telRendsburgLink} class="text-white text-sm hover:text-route transition">{site.phoneRendsburgDisplay}</a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="pt-8 flex flex-col md:flex-row md:justify-between gap-4 text-xs text-white/45">
      <p>(c) {year} {site.legalName} - {site.legal.hra} - USt-IdNr. {site.legal.ustIdNr}</p>
      <div class="flex flex-wrap gap-5">
        {legalNav.map((i) => (<a href={i.href} class="hover:text-white transition">{i.label}</a>))}
        <span class="text-white/30">Cash für Chrom DMAX - Shelby Partner - EST. 1989</span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer-social {
    width: 40px; height: 40px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.7);
    display: inline-flex; align-items: center; justify-content: center;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }
  .footer-social:hover {
    background: rgb(185 28 28);
    border-color: rgb(185 28 28);
    color: #fff;
    transform: translateY(-2px);
  }
  .footer-social-text {
    display: inline-flex;
    align-items: center;
    padding: 0 0.95rem;
    height: 40px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.78rem;
    font-weight: 500;
    transition: background 0.3s ease, border-color 0.3s ease, color 0.3s ease, transform 0.3s ease;
  }
  .footer-social-text:hover {
    background: rgb(185 28 28);
    border-color: rgb(185 28 28);
    color: #fff;
    transform: translateY(-2px);
  }
</style>
