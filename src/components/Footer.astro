---
import { site, telLink, telRendsburgLink, mailLink, mailWorkshopLink, whatsappLink, legalNav } from '../data/site';
import { services } from '../data/services';
import Icon from './Icon.astro';
const year = new Date().getFullYear();

const company = [
  { href: '/team', label: 'Team' },
  { href: '/jobs', label: 'Jobs' },
  { href: '/presse', label: 'Presse' },
  { href: '/galerie', label: 'Galerie' },
  { href: '/kontakt', label: 'Kontakt' },
];
---

<footer class="section-dark pt-24 pb-10">
  <div class="container-r66">
    <div class="grid md:grid-cols-12 gap-12 pb-14 border-b border-white/10">
      <div class="md:col-span-4">
        <a href="/" class="inline-flex items-center gap-3 mb-6" aria-label="Route 66 Borrmann Motors KG">
          <img src="/images/route66-logo.png" alt="Route 66 Borrmann Motors KG" width="180" height="180" class="h-14 w-auto" style="filter: brightness(1.05);" />
          <span class="flex flex-col leading-tight">
            <span class="font-display text-lg font-medium text-white leading-none">Route 66</span>
            <span class="text-[0.72rem] text-white/55 leading-none mt-1">Borrmann Motors KG</span>
          </span>
        </a>
        <p class="text-white/60 leading-relaxed max-w-sm mb-7">
          US-Cars, Classic Cars, Oldtimer und Youngtimer. KFZ-Meisterbetrieb in Hamburg-Bahrenfeld. Bekannt aus Cash für Chrom. EST. 1989.
        </p>
        <div class="flex flex-wrap gap-2.5">
          <a href={site.social.instagram} target="_blank" rel="noopener" aria-label="Instagram" class="w-10 h-10 rounded-md inline-flex items-center justify-center border border-white/15 text-white/70 hover:text-white hover:border-white/40 transition">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor"/></svg>
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener" aria-label="Facebook" class="w-10 h-10 rounded-md inline-flex items-center justify-center border border-white/15 text-white/70 hover:text-white hover:border-white/40 transition">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M22 12c0-5.5-4.5-10-10-10S2 6.5 2 12c0 5 3.7 9.1 8.4 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.3v7c4.6-.8 8.4-4.9 8.4-9.9z"/></svg>
          </a>
          <a href={site.social.youtube} target="_blank" rel="noopener" aria-label="YouTube" class="w-10 h-10 rounded-md inline-flex items-center justify-center border border-white/15 text-white/70 hover:text-white hover:border-white/40 transition">
            <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M23.5 6.2c-.3-1-1-1.8-2-2.1C19.6 3.5 12 3.5 12 3.5s-7.6 0-9.5.6c-1 .3-1.7 1.1-2 2.1C0 8.1 0 12 0 12s0 3.9.5 5.8c.3 1 1 1.8 2 2.1 1.9.6 9.5.6 9.5.6s7.6 0 9.5-.6c1-.3 1.7-1.1 2-2.1.5-1.9.5-5.8.5-5.8s0-3.9-.5-5.8zM9.6 15.6V8.4l6.3 3.6-6.3 3.6z"/></svg>
          </a>
          <a href={whatsappLink} target="_blank" rel="noopener" aria-label="WhatsApp" class="w-10 h-10 rounded-md inline-flex items-center justify-center border border-white/15 text-white/70 hover:text-white hover:border-white/40 transition">
            <Icon name="MessageCircle" size={16} />
          </a>
        </div>
      </div>

      <div class="md:col-span-2">
        <h3 class="text-white text-sm font-medium mb-5">Services</h3>
        <ul class="space-y-3">
          {services.map((s) => (<li><a href={s.href} class="nav-link-footer">{s.title}</a></li>))}
        </ul>
      </div>

      <div class="md:col-span-2">
        <h3 class="text-white text-sm font-medium mb-5">Borrmann Motors</h3>
        <ul class="space-y-3">
          {company.map((i) => (<li><a href={i.href} class="nav-link-footer">{i.label}</a></li>))}
          {legalNav.map((i) => (<li><a href={i.href} class="nav-link-footer">{i.label}</a></li>))}
        </ul>
      </div>

      <div class="md:col-span-4">
        <h3 class="text-white text-sm font-medium mb-5">Hamburg - Hauptstandort</h3>
        <address class="not-italic text-white/60 leading-relaxed mb-4">
          {site.address.street}<br />
          {site.address.streetDetail}<br />
          {site.address.postal} {site.address.city}
        </address>
        <ul class="space-y-2 text-sm mb-6">
          <li><a href={telLink} class="nav-link-footer inline-flex items-center gap-2"><Icon name="Phone" size={13} class="text-route" />{site.phoneDisplay}</a></li>
          <li><a href={mailLink} class="nav-link-footer inline-flex items-center gap-2 break-all"><Icon name="Mail" size={13} class="text-route" />{site.email}</a></li>
          <li><a href={mailWorkshopLink} class="nav-link-footer inline-flex items-center gap-2 break-all"><Icon name="Wrench" size={13} class="text-route" />{site.emailWorkshop}</a></li>
        </ul>
        <p class="text-white/55 text-sm leading-relaxed mb-6">
          Mo - Do: 8 - 17 Uhr · Fr: 8 - 15 Uhr<br />
          Sa: Nach Vereinbarung
        </p>

        <h3 class="text-white text-sm font-medium mb-4">Zweigstelle Rendsburg</h3>
        <address class="not-italic text-white/60 leading-relaxed mb-2 text-sm">
          {site.addressRendsburg.street}, {site.addressRendsburg.postal} {site.addressRendsburg.city}
        </address>
        <a href={telRendsburgLink} class="nav-link-footer inline-flex items-center gap-2"><Icon name="Phone" size={13} class="text-route" />{site.phoneRendsburgDisplay}</a>
      </div>
    </div>

    <div class="pt-8 flex flex-col md:flex-row md:justify-between gap-3 text-xs text-white/45">
      <p>(c) {year} {site.legalName} - {site.legal.hra} - USt-IdNr. {site.legal.ustIdNr}</p>
      <div class="flex flex-wrap gap-5">
        {legalNav.map((i) => (<a href={i.href} class="hover:text-white transition">{i.label}</a>))}
      </div>
    </div>
  </div>
</footer>
