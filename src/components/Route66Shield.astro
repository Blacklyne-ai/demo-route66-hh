---
// Decorative Route 66 highway shield - used as section watermarks
interface Props {
  class?: string;
  size?: number;
  opacity?: number;
}
const { class: className = '', size = 320, opacity = 0.06 } = Astro.props;
---
<svg
  width={size}
  height={size}
  viewBox="0 0 100 120"
  fill="none"
  aria-hidden="true"
  class={`pointer-events-none ${className}`}
  style={`opacity: ${opacity};`}
>
  <!-- Shield outline -->
  <path
    d="M50 6 C 70 6, 90 18, 92 36 C 92 70, 70 100, 50 114 C 30 100, 8 70, 8 36 C 10 18, 30 6, 50 6 Z"
    fill="currentColor"
  />
  <!-- Inner white space -->
  <path
    d="M50 14 C 66 14, 84 24, 86 38 C 86 66, 68 92, 50 105 C 32 92, 14 66, 14 38 C 16 24, 34 14, 50 14 Z"
    fill="rgb(250 247 240)"
  />
  <!-- "U.S." -->
  <text x="50" y="36" text-anchor="middle" font-family="Oswald, sans-serif" font-size="10" font-weight="700" fill="currentColor" letter-spacing="0.05em">U.S.</text>
  <!-- Bar -->
  <line x1="20" y1="44" x2="80" y2="44" stroke="currentColor" stroke-width="1.5"/>
  <!-- "ROUTE" -->
  <text x="50" y="58" text-anchor="middle" font-family="Oswald, sans-serif" font-size="9" font-weight="600" fill="currentColor" letter-spacing="0.08em">ROUTE</text>
  <!-- Big "66" -->
  <text x="50" y="88" text-anchor="middle" font-family="Oswald, sans-serif" font-size="34" font-weight="700" fill="currentColor">66</text>
</svg>
