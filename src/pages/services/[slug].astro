---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Icon from '../../components/Icon.astro';
import CtaBand from '../../components/CtaBand.astro';
import { services } from '../../data/services';
import { telLink, whatsappLink, site } from '../../data/site';

export async function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
---

<Layout
  title={`${service.title} - Route 66 Hamburg | Klaus Borrmann`}
  description={service.tagline}
  current={`/services/${service.slug}`}
>
  <PageHero
    eyebrow={service.eyebrow}
    title={service.title}
    lead={service.tagline}
    image={service.image}
    cta={{ label: service.cta, href: telLink, icon: 'Phone' }}
    secondaryCta={{ label: 'WhatsApp', href: whatsappLink, icon: 'MessageCircle' }}
    breadcrumbs={[
      { label: 'Startseite', href: '/' },
      { label: 'Services', href: '/services' },
      { label: service.title, href: `/services/${service.slug}` },
    ]}
  />

  <!-- LEAD + PRICE - editorial split -->
  <section class="section-light section-padding">
    <div class="container-r66">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-7 fade-in">
          <p class="num-label">Worum es geht</p>
          <p class="text-xl md:text-2xl text-onyx leading-relaxed text-pretty">{service.lead}</p>

          <div class="mt-12 pt-10 border-t border-line">
            <p class="num-label mb-4">Das ist inklusive</p>
            <ul class="grid sm:grid-cols-2 gap-x-8 gap-y-3.5">
              {service.includes.map((inc) => (
                <li class="flex items-start gap-3 group">
                  <span class="w-6 h-6 rounded-full bg-route/10 text-route inline-flex items-center justify-center flex-shrink-0 mt-0.5 group-hover:bg-route group-hover:text-white transition-colors">
                    <Icon name="Check" size={12} strokeWidth={2.5} />
                  </span>
                  <span class="text-onyx text-sm">{inc}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="lg:col-span-5 fade-in stagger-1">
          {service.price && (
            <div class="rounded-2xl p-8 mb-5" style="background: linear-gradient(160deg, #111 0%, #1A1A1A 100%); color: #fff;">
              <p class="text-[0.72rem] tracking-[0.18em] uppercase text-route mb-3 font-medium">Pauschal-Preis</p>
              <p class="font-display text-5xl text-white leading-none mb-3">{service.price}</p>
              <p class="text-white/70 text-sm mb-6">Inkl. MwSt. - fair, transparent, kein Kleingedrucktes.</p>
              <a href={telLink} class="btn btn-light btn-block !rounded-full">
                <Icon name="Phone" size={14} strokeWidth={2} />
                Direkt anrufen
              </a>
            </div>
          )}
          <div class="card !p-7">
            <div class="flex items-center gap-3 mb-5">
              <span class="w-10 h-10 rounded-full bg-route/10 text-route inline-flex items-center justify-center">
                <Icon name="Phone" size={16} strokeWidth={2} />
              </span>
              <div>
                <p class="font-display text-onyx font-medium leading-tight">Lieber direkt sprechen?</p>
                <p class="text-muted text-xs mt-0.5">Ruf Klaus an, schreib uns auf WhatsApp.</p>
              </div>
            </div>
            <div class="space-y-2 pt-4 border-t border-line">
              <a href={telLink} class="flex items-center justify-between text-sm hover:text-route transition group">
                <span class="text-muted">Hamburg</span>
                <span class="font-medium text-onyx group-hover:text-route">{site.phoneDisplay}</span>
              </a>
              <a href={whatsappLink} target="_blank" rel="noopener" class="flex items-center justify-between text-sm hover:text-route transition group">
                <span class="text-muted">WhatsApp</span>
                <span class="font-medium text-onyx group-hover:text-route inline-flex items-center gap-1">Direkt schreiben <Icon name="ArrowUpRight" size={12} strokeWidth={2} /></span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS STEPS - Premium Timeline mit Connection Line -->
  <section class="section-warm section-padding relative overflow-hidden">
    <div class="container-r66 relative">
      <SectionHeading
        eyebrow="So funktioniert's"
        title="In vier Schritten zum Ergebnis."
        lead="Online buchen, Anliegen schildern, bezahlen, Rückruf erhalten. Keine Wartezeit am Telefon, keine Floskeln."
      />

      <div class="mt-16 relative">
        <!-- Connecting line on desktop -->
        <div class="hidden lg:block absolute top-12 left-[12.5%] right-[12.5%] h-px" style="background: repeating-linear-gradient(90deg, rgba(185,28,28,0.4) 0px, rgba(185,28,28,0.4) 6px, transparent 6px, transparent 14px);" aria-hidden="true"></div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 relative">
          {service.features.map((f, i) => (
            <div class={`step-card fade-in stagger-${i + 1}`}>
              <!-- Step number badge -->
              <div class="relative inline-flex mb-6">
                <span class="step-num w-24 h-24 rounded-full bg-white border-2 border-line inline-flex items-center justify-center relative z-10 transition-all duration-500" style="box-shadow: 0 8px 24px -8px rgba(0,0,0,0.12);">
                  <span class="font-display text-4xl text-onyx font-medium leading-none">{String(i + 1).padStart(2, '0')}</span>
                </span>
                <span class="absolute -top-1 -right-1 w-9 h-9 rounded-full bg-route text-white inline-flex items-center justify-center z-20 shadow-lg">
                  <Icon name={f.icon} size={15} strokeWidth={2} />
                </span>
              </div>
              <h3 class="heading-md mb-3">{f.title}</h3>
              <p class="text-muted leading-relaxed text-sm">{f.body}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-16 text-center fade-in">
        <a href={telLink} class="btn btn-primary btn-lg group">
          <Icon name="Phone" size={16} strokeWidth={2} />
          Jetzt anrufen - {site.phoneDisplay}
          <span class="hover-arrow inline-flex"><Icon name="ArrowRight" size={15} strokeWidth={2} /></span>
        </a>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>

<style>
  .step-card:hover .step-num {
    border-color: rgb(185, 28, 28);
    transform: scale(1.04);
    box-shadow: 0 14px 36px -10px rgba(185,28,28,0.3);
  }
</style>
