---
import Layout from '../../layouts/Layout.astro';
import PageHero from '../../components/PageHero.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import Icon from '../../components/Icon.astro';
import CtaBand from '../../components/CtaBand.astro';
import { services } from '../../data/services';
import { telLink, whatsappLink, site } from '../../data/site';

export async function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;

// Map each service to a different complementary image so the lead-section
// has visual variety (no twice the same hero image on one page).
const sideImageMap: Record<string, string> = {
  'call-a-mechanic': '/images/team-header.jpg',
  'car-check': '/images/car-design-2.jpg',
  'car-design': '/images/car-design-2.jpg',
  'call-for-parts': '/images/car-design-1.jpg',
  'werkstattfuehrung': '/images/team-header.jpg',
};
const sideImage = sideImageMap[service.slug] ?? '/images/team-group.jpg';
---

<Layout
  title={`${service.title} - Route 66 Hamburg | Klaus Borrmann`}
  description={service.tagline}
  current={`/services/${service.slug}`}
>
  <PageHero
    eyebrow={service.eyebrow}
    title={service.title}
    lead={service.tagline}
    image={service.image}
    cta={{ label: service.cta, href: telLink, icon: 'Phone' }}
    secondaryCta={{ label: 'WhatsApp', href: whatsappLink, icon: 'MessageCircle' }}
    breadcrumbs={[
      { label: 'Startseite', href: '/' },
      { label: 'Services', href: '/services' },
      { label: service.title, href: `/services/${service.slug}` },
    ]}
  />

  <!-- LEAD - editorial mit Image + Price-Card + Inklusiv-Liste -->
  <section class="section-light section-padding">
    <div class="container-r66">
      <!-- Top split: Side image + lead text -->
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16 items-center mb-20">
        <div class="lg:col-span-5 fade-in">
          <div class="relative">
            <div class="rounded-xl overflow-hidden aspect-[4/5] bg-cream-warm">
              <img src={sideImage} alt={service.title} class="w-full h-full object-cover" loading="lazy" />
            </div>
            <!-- Floating Klaus-quote card -->
            <div class="absolute -bottom-5 -right-5 max-w-[250px] rounded-lg p-5 hidden sm:block" style="background: #fff; border: 1px solid #E2DBCD; box-shadow: 0 22px 48px -16px rgba(0,0,0,0.18);">
              <div class="flex items-start gap-3 mb-3">
                <div class="w-9 h-9 rounded-full overflow-hidden flex-shrink-0 bg-cream-warm">
                  <img src="/images/klaus-borrmann.jpg" alt="Klaus Borrmann" class="w-full h-full object-cover" />
                </div>
                <div>
                  <p class="font-display text-onyx text-sm font-medium leading-tight">Klaus Borrmann</p>
                  <p class="text-[0.66rem] text-muted">Inhaber & KFZ-Meister</p>
                </div>
              </div>
              <p class="text-onyx text-[0.78rem] leading-snug italic">"Ein Anruf, ein klarer Plan - und Du weißt, was wirklich Sache ist."</p>
            </div>
          </div>
        </div>

        <div class="lg:col-span-7 fade-in stagger-1">
          <p class="num-label">Worum es geht</p>
          <p class="text-xl md:text-2xl text-onyx leading-relaxed text-pretty mb-10">{service.lead}</p>

          <!-- Price + Inklusiv split -->
          <div class="grid sm:grid-cols-12 gap-5">
            {service.price && (
              <div class="sm:col-span-5 rounded-2xl p-7" style="background: linear-gradient(160deg, #111 0%, #1A1A1A 100%); color: #fff;">
                <p class="text-[0.7rem] tracking-[0.18em] uppercase text-route mb-3 font-medium">Pauschal-Preis</p>
                <p class="font-display text-4xl text-white leading-none mb-3">{service.price}</p>
                <p class="text-white/70 text-xs leading-relaxed mb-5">Inkl. MwSt. Fair, transparent, kein Kleingedrucktes.</p>
                <a href={telLink} class="btn btn-light btn-sm btn-block !rounded-full">
                  <Icon name="Phone" size={13} strokeWidth={2} />
                  Direkt anrufen
                </a>
              </div>
            )}
            <div class={`${service.price ? 'sm:col-span-7' : 'sm:col-span-12'} rounded-2xl p-7 bg-white border border-line`}>
              <p class="text-[0.7rem] tracking-[0.18em] uppercase text-route mb-4 font-medium">Das ist inklusive</p>
              <ul class="space-y-2.5">
                {service.includes.map((inc) => (
                  <li class="flex items-start gap-2.5 text-sm">
                    <Icon name="Check" size={13} strokeWidth={2.5} class="text-route mt-1 flex-shrink-0" />
                    <span class="text-onyx leading-snug">{inc}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESS STEPS - Premium Timeline mit Connection Line -->
  <section class="section-warm section-padding relative overflow-hidden">
    <div class="container-r66 relative">
      <SectionHeading
        eyebrow="So funktioniert's"
        title="In vier Schritten zum Ergebnis."
        lead="Online buchen, Anliegen schildern, bezahlen, Rückruf erhalten. Keine Wartezeit am Telefon, keine Floskeln."
      />

      <div class="mt-16 relative">
        <div class="hidden lg:block absolute top-12 left-[12.5%] right-[12.5%] h-px" style="background: repeating-linear-gradient(90deg, rgba(185,28,28,0.4) 0px, rgba(185,28,28,0.4) 6px, transparent 6px, transparent 14px);" aria-hidden="true"></div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 relative">
          {service.features.map((f, i) => (
            <div class={`step-card fade-in stagger-${i + 1}`}>
              <div class="relative inline-flex mb-6">
                <span class="step-num w-24 h-24 rounded-full bg-white border-2 border-line inline-flex items-center justify-center relative z-10 transition-all duration-500" style="box-shadow: 0 8px 24px -8px rgba(0,0,0,0.12);">
                  <span class="font-display text-4xl text-onyx font-medium leading-none">{String(i + 1).padStart(2, '0')}</span>
                </span>
                <span class="absolute -top-1 -right-1 w-9 h-9 rounded-full bg-route text-white inline-flex items-center justify-center z-20 shadow-lg">
                  <Icon name={f.icon} size={15} strokeWidth={2} />
                </span>
              </div>
              <h3 class="heading-md mb-3">{f.title}</h3>
              <p class="text-muted leading-relaxed text-sm">{f.body}</p>
            </div>
          ))}
        </div>
      </div>

      <div class="mt-16 text-center fade-in">
        <a href={telLink} class="btn btn-primary btn-lg group">
          <Icon name="Phone" size={16} strokeWidth={2} />
          Jetzt anrufen - {site.phoneDisplay}
          <span class="hover-arrow inline-flex"><Icon name="ArrowRight" size={15} strokeWidth={2} /></span>
        </a>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>

<style>
  .step-card:hover .step-num {
    border-color: rgb(185, 28, 28);
    transform: scale(1.04);
    box-shadow: 0 14px 36px -10px rgba(185,28,28,0.3);
  }
</style>
