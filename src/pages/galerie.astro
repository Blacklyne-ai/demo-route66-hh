---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Icon from '../components/Icon.astro';
import CtaBand from '../components/CtaBand.astro';
import { site } from '../data/site';

const galleryItems = [
  { src: '/images/klaus-borrmann.jpg', title: 'Klaus Borrmann', subtitle: 'Inhaber & TV-Persoenlichkeit' },
  { src: '/images/team-group.jpg', title: 'Das Route 66 Team', subtitle: 'Hamburg & Rendsburg vereint' },
  { src: '/images/car-check-hero.jpg', title: 'Werkstatt im Einsatz', subtitle: 'Hamburg-Bahrenfeld' },
  { src: '/images/car-design-1.jpg', title: 'Borrmann Motors Racing 66', subtitle: 'Custom Design Build' },
  { src: '/images/car-design-2.jpg', title: 'Custom Showcase', subtitle: 'Eigene Werkstatt-Projekte' },
  { src: '/images/michel-schmidt.jpg', title: 'Michel Schmidt', subtitle: '40 Jahre Ersatzteile' },
  { src: '/images/fred-fiedler.jpg', title: 'Fred Fiedler', subtitle: 'KFZ-Meister seit 30 Jahren' },
  { src: '/images/bjoern.jpg', title: 'Bjoern', subtitle: 'Rendsburg Standort' },
  { src: '/images/team-header.jpg', title: 'Werkstatt-Atmosphaere', subtitle: 'Wo Leidenschaft auf Motoren trifft' },
];
---

<Layout
  title="Car-Galerie - Route 66 Hamburg | US-Cars & Werkstatt-Impressionen"
  description="Car-Galerie von Route 66 Borrmann Motors Hamburg - Klaus, Team, US-Cars, Werkstatt-Projekte, Custom Designs."
  current="/galerie"
>
  <PageHero
    eyebrow="Car-Galerie"
    title="Bilder sagen mehr."
    lead="Klaus, das Team, die Werkstatt, die Cars. Echte Eindruecke aus 35 Jahren Route 66 Hamburg."
    image="/images/team-header.jpg"
    breadcrumbs={[{ label: 'Startseite', href: '/' }, { label: 'Galerie', href: '/galerie' }]}
  />

  <section class="section-cream py-20 md:py-28">
    <div class="container-r66">
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {galleryItems.map((item, i) => (
          <div class={`group relative aspect-[4/5] overflow-hidden rounded-lg bg-onyx fade-in stagger-${(i % 4) + 1}`}>
            <img src={item.src} alt={item.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
            <div class="absolute inset-0 bg-gradient-to-t from-onyx via-onyx/30 to-transparent opacity-90"></div>
            <div class="absolute bottom-0 left-0 right-0 p-5">
              <h3 class="font-display text-lg font-bold uppercase tracking-wide text-white">{item.title}</h3>
              <p class="text-white/75 text-xs mt-1">{item.subtitle}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-14 text-center">
        <p class="text-muted mb-6">Mehr Eindruecke gibt's auf unseren Social-Kanaelen.</p>
        <div class="flex flex-wrap items-center justify-center gap-3">
          <a href={site.social.instagram} target="_blank" rel="noopener" class="btn btn-dark btn-lg">
            <Icon name="Camera" size={16} strokeWidth={2.2} />
            Instagram
            <Icon name="ExternalLink" size={14} strokeWidth={2.2} />
          </a>
          <a href={site.social.youtube} target="_blank" rel="noopener" class="btn btn-outline btn-lg">
            <Icon name="Tv2" size={16} strokeWidth={2.2} />
            YouTube
            <Icon name="ExternalLink" size={14} strokeWidth={2.2} />
          </a>
          <a href={site.external.autoscout24} target="_blank" rel="noopener" class="btn btn-primary btn-lg">
            <Icon name="Car" size={16} strokeWidth={2.2} />
            Aktuelle Fahrzeuge
            <Icon name="ExternalLink" size={14} strokeWidth={2.2} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <CtaBand />
</Layout>
