---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingCTA from '../components/FloatingCTA.astro';
import CookieBanner from '../components/CookieBanner.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import ScrollProgress from '../components/ScrollProgress.astro';
import JobBanner from '../components/JobBanner.astro';
import { site } from '../data/site';

interface Props {
  title: string;
  description?: string;
  current?: string;
  ogImage?: string;
  noindex?: boolean;
  schema?: object | null;
}

const {
  title,
  description = site.description,
  current = '',
  ogImage = '/images/klaus-borrmann.jpg',
  noindex = false,
  schema = null,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.url).toString();
const ogImageUrl = new URL(ogImage, site.url).toString();
---

<!doctype html>
<html lang="de-DE">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>document.documentElement.classList.add('js');</script>
    <link rel="icon" type="image/png" href="/images/route66-logo.png" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="de-DE" href={canonical} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex
      ? <meta name="robots" content="noindex, follow" />
      : <meta name="robots" content="index, follow" />}
    <meta name="theme-color" content="#0A0A0A" />
    <meta name="author" content={site.name} />
    <meta name="keywords" content="US Cars, route66 Hamburg, US Oldtimer, US Youngtimer, US Neuwagen, Klaus Borrmann, Cash für Chrom Hamburg, Shelby Service Partner Deutschland, US-Car Import Hamburg, Muscle Car Hamburg, KFZ-Meisterbetrieb Hamburg, Werkstatt Bahrenfeld, Oldtimer Hamburg, Classic Car Hamburg" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="de_DE" />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <SchemaOrg schema={schema} />
  </head>
  <body>
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <ScrollProgress />
    <JobBanner />
    <Header current={current} />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <FloatingCTA />
    <CookieBanner />

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('is-visible');
              io.unobserve(e.target);
            }
          });
        },
        { rootMargin: '0px 0px -50px 0px', threshold: 0.05 }
      );
      document.querySelectorAll('.fade-in').forEach((el) => io.observe(el));
    </script>

    <style is:global>
      .skip-link {
        position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
        overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
      }
      .skip-link:focus {
        position: fixed; top: 1rem; left: 1rem; width: auto; height: auto; clip: auto;
        padding: 0.75rem 1.25rem; background: #B91C1C; color: #fff; border-radius: 8px; z-index: 100;
        font-weight: 600;
      }
    </style>
  </body>
</html>
